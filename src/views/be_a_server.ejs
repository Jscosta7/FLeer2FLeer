<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Be a Server - FL WebServer</title>
  
  <link rel ="stylesheet" href="/stylesheets/style.css">
  <link rel ="stylesheet" href="/stylesheets/trainingstyle.css">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>
    /* --- ESTRUTURA PRINCIPAL --- */
    /* Layout fluido com rolagem nativa que NUNCA corta o conteúdo */
    .main-content {
        width: 80%; /* Ocupa o espaço exato ao lado do menu (20%) */
        height: 100vh; /* Limita à altura do navegador... */
        overflow-y: auto; /* ...e cria a barra de rolagem AQUI dentro */
        background-color: #F1F5F9; /* Fundo gelo padronizado */
        padding: 40px 2rem; /* Espaço generoso no topo e no fundo */
        box-sizing: border-box;
        display: block; /* Removemos o Flexbox daqui para evitar o corte da tela */
    }
    
    /* O container do formulário (sem cara de "card preso", centralizado livremente) */
    .server-card-large {
        width: 100%;
        max-width: 800px; /* Limita a largura para a leitura do formulário ficar agradável */
        margin: 0 auto; /* A MÁGICA: Centraliza horizontalmente de forma segura */
        display: flex;
        flex-direction: column;
    }

    /* --- FORMULÁRIO E TIPOGRAFIA --- */
    .form-group { margin-bottom: 25px; }
    
    .form-label { 
        display: block;
        font-weight: 600; 
        color: #1E293B; /* Texto Ardósia Escuro */
        font-size: 1rem; 
        margin-bottom: 10px;
    }
    
    .form-input { 
        width: 100%; 
        padding: 16px; 
        font-size: 1rem;
        border: 1px solid #CBD5E1; /* Borda fina e elegante */
        border-radius: 8px; 
        font-family: 'Inter', sans-serif; 
        box-sizing: border-box; 
        background-color: #FFFFFF; /* Inputs brancos para destacar no fundo cinza */
        color: #0F172A;
        transition: all 0.2s ease;
    }
    
    .form-input:focus, select.form-input:focus { 
        outline: none; 
        border-color: #63DBB8; 
        box-shadow: 0 0 0 4px rgba(99, 219, 184, 0.15); /* Efeito de foco (glow) */
    }

    .form-row-dual { 
        display: flex; 
        gap: 25px; 
    }

    /* Responsividade: Empilha os campos "Category" e "Area" em laptops menores */
    @media (max-width: 900px) {
        .form-row-dual {
            flex-direction: column;
            gap: 0;
        }
    }

    /* --- ÁREA DE UPLOAD (Exclusiva desta tela) --- */
    .upload-area {
        border: 2px dashed #CBD5E1; /* Borda tracejada sutil */
        background-color: #FFFFFF; /* Fundo branco para sobressair */
        padding: 50px; 
        text-align: center;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-bottom: 20px;
    }
    
    .upload-area:hover { 
        border-color: #63DBB8; 
        background-color: rgba(99, 219, 184, 0.05); /* Fica levemente verde ao passar o mouse */
    }

    /* --- BOTÕES --- */
    .form-actions { 
        display: flex; 
        justify-content: flex-end; 
        align-items: center; 
        gap: 20px; 
        margin-top: 20px;
        padding-top: 30px; 
        border-top: 1px solid #E2E8F0; /* Linha divisória clara */
    }
    
    .btn-primary { 
        background-color: #63DBB8; 
        color: #042F2E; /* Texto com alto contraste */
        padding: 14px 30px;
        border: none; 
        border-radius: 8px; 
        font-size: 1.1rem; 
        font-weight: 600; 
        cursor: pointer; 
        transition: transform 0.1s ease, background-color 0.2s; 
        display: flex; align-items: center; gap: 10px; 
    }
    .btn-primary:hover { 
        transform: translateY(-2px); 
        background-color: #4acda3; 
        box-shadow: 0 4px 12px rgba(99, 219, 184, 0.2);
    }
    
    .btn-secondary { 
        font-family: 'Helvetica', sans-serif;
        background-color: transparent; 
        color: #64748B; 
        padding: 12px 24px; 
        border: 1px solid transparent; 
        border-radius: 8px; 
        text-decoration: none; 
        font-weight: 600; 
        font-size: 1rem; 
        transition: all 0.2s;
    }
    .btn-secondary:hover { 
        color: #1E293B; 
        background-color: #E2E8F0; 
    }
  </style>
</head>

<body class="page-training">

<div class="screen">
    
    <div class="side-menu">
        <div class="menu-header">
            <a href="/" class="menu-logo">
                <i class="fa-solid fa-network-wired"></i>
                <h2>FL WebServer</h2>
            </a>
        </div>

        <nav class="menu-nav">
            <ul>
                <li>
                    <a href="/">
                        <i class="fa-solid fa-table-list"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li>
                    <a href="/be_a_server" class="active">
                        <i class="fa-solid fa-handshake"></i>
                        <span>Be a server</span>
                    </a>
                </li>
                <li>
                    <a href="/report">
                        <i class="fa-solid fa-bullhorn"></i>
                        <span>Report</span>
                    </a>
                </li>
            </ul>
        </nav>

        <div class="menu-footer">
            <a href="#">
                <i class="fa-regular fa-user"></i>
                <span>User</span>
            </a>
            <a href="#">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Logout</span>
            </a>
        </div>
    </div>

    <div class="main-content" style="padding: 2rem; width: 100%; display: flex; justify-content: center;">
        
        <div class="server-card" style="max-width: 800px; width: 100%; height: fit-content;">
            
            <h1 style="font-size: 2.8rem ;border-bottom: 1px solid #63DBB8 ; padding-bottom: 10px; margin-bottom: 20px;">
                <i class="fa-solid fa-server" style="color: #63DBB8; margin-right: 10px;"></i>
                Register New Node
            </h1>
            
            <p style="font-size: 1.25rem; color: #666; margin-bottom: 30px;">
                Join the Federation. Share your computational resources to help train global models securely.
            </p>

            <form action="/be_a_server" method="POST" enctype="multipart/form-data">
                
                <div class="form-row-dual">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Category</label>
                        <select class="form-input" name="category">
                            <option value="Neural Network">Neural Network</option>
                            <option value="Linear Regression">Linear Regression</option>
                            <option value="Gaussian Mixture">Gaussian Mixture</option>
                            <option value="Q-Learning">Q-Learning</option>
                        </select>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Application Area</label>
                        <input type="text" class="form-input" name="application" placeholder="e.g., Medical Imaging" required>
                    </div>
                </div>

                <div class="form-row-dual">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Hardware Description (Optional)</label>
                        <input type="text" class="form-input" name="hardware" placeholder="e.g., 8x NVIDIA A100">
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Upload Client Code (.py)</label>
                    <div class="upload-area" onclick="document.getElementById('fileInput').click()">
                        <i class="fa-solid fa-cloud-arrow-up" style="font-size: 2.5rem; color: #63DBB8; margin-bottom: 10px;"></i>
                        <p style="color: #555; margin: 0;"><strong>Click to upload</strong> or drag and drop</p>
                        <p style="color: #999; font-size: 0.8rem; margin-top: 5px;">Python files only (client.py)</p>
                        <input type="file" id="fileInput" name="clientFile" style="display: none;" onchange="fileSelected(this)" required accept=".py">
                    </div>
                    <p id="fileNameDisplay" style="margin-top: 5px; color: #63DBB8; font-weight: bold; display: none;"></p>
                </div>

                <div class="form-actions">
                    <a href="/" class="btn-secondary">Cancel</a>
                    <button type="submit" class="btn-primary">
                        Submit Application <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

<script>
    function fileSelected(input) {
        const display = document.getElementById('fileNameDisplay');
        if (input.files && input.files[0]) {
            display.style.display = 'block';
            display.textContent = 'Selected file: ' + input.files[0].name;
        }
    }

</script>

</body>
</html>
