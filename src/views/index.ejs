<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = io();
  
socket.on("statusUpdate", (data) => {
  console.log("Recebi:", data);
  const lastUpdateCell = document.getElementById(`last-update-${data.id}`);
  if(lastUpdateCell){
    lastUpdateCell.dataset.timestamp = data.Last_Update; // atualiza o timestamp original
    lastUpdateCell.textContent = timeAgo(data.Last_Update); // atualiza imediatamente
  }

  // ATUALIZAÇÃO DE DOWNLOADS EM TEMPO REAL
    const downloadsCell = document.getElementById(`downloads-${data.id}`);
    if (downloadsCell) {
        downloadsCell.textContent = data.Downloads;
    }

  
  const statusCell = document.getElementById(`status-${data.id}`);
  if (statusCell) {
    // Atualiza o data-value para a ordenação funcionar
    statusCell.dataset.value = data.Sever_status;

    // Determina qual classe de cor usar (online ou offline)
    const statusClass = data.Sever_status === 'online' ? 'online' : 'offline';
    
    // Recria o HTML do badge dentro da célula para garantir que o estilo seja aplicado
    statusCell.innerHTML = `
        <div class="status-badge ${statusClass}">
            <span class="status-dot"></span>
            <span class="status-text">${data.Sever_status}</span>
        </div>
    `;
  }


  const avgCell = document.getElementById(`avg-${data.id}`);
  const completedCell = document.getElementById(`completed-${data.id}`);

  if (avgCell) avgCell.textContent = data.Average_round_duration ? Math.round(data.Average_round_duration) : '-';
  if (completedCell) completedCell.textContent = data.Completed_Rounds;

  const row = document.getElementById(`server-${data.id}`);
  if(row){
    const link = row.querySelector('a.btn');
    if(link){
      if(data.Sever_status === 'online'){
        link.className = 'btn btn-running'; 
        link.innerHTML = `<span>See Training</span><i class="fa-solid fa-arrow-right"></i>`;            
        link.href = `/training/${data.id}`;
      } else {
        link.className = 'btn btn-history';
        link.innerHTML = `<span>See History</span><i class="fa-solid fa-eye"></i>`;
        link.href = `/training/${data.id}?offline=true`;
      }
    }
  }

  reattachSortEvents();
});


  function timeAgo(timestamp) {
  const now = new Date();
  const past = new Date(timestamp);
  const diff = (now - past) / 1000; // diferença em segundos

  if (diff < 60) {
    return `${Math.floor(diff)}s`; // segundos
  } else if (diff < 3600) {
    return `${Math.floor(diff / 60)}m`; // minutos
  } else if (diff < 86400) {
    return `${Math.floor(diff / 3600)}h`; // horas
  } else {
    const days = Math.floor(diff / 86400);
    return days === 1 ? '1d' : `${days}d`; // dias
  }
}


// Função que atualiza todas as células de Last_Update
function updateLastUpdateCells() {
  document.querySelectorAll('[id^="last-update-"]').forEach(cell => {
    const timestamp = cell.dataset.timestamp;
    if (timestamp) cell.textContent = timeAgo(timestamp);
  });
}

// Atualiza imediatamente ao carregar a página
updateLastUpdateCells();

// Atualiza a cada 10 segundos
setInterval(updateLastUpdateCells, 10000);
let sortPriority = [];
let sortDirections = {};

// Utilitários
function getTableForServer() {
  // retorna a primeira table cujo id comece com "server" (server-table, serverTable, etc.)
  return document.querySelector('table[id^="server"]');
}

function applySort(table) {
  if (!table) return;
  const tbody = table.tBodies[0];
  if (!tbody) return;

  const rows = Array.from(tbody.rows);
  rows.sort((a, b) => {
    for (let col of sortPriority) {
      const cellA = a.cells[col];
      const cellB = b.cells[col];
      if (!cellA || !cellB) continue;

      const rawA = (cellA.dataset.value ?? cellA.dataset.timestamp ?? cellA.innerText).toString().trim();
      const rawB = (cellB.dataset.value ?? cellB.dataset.timestamp ?? cellB.innerText).toString().trim();

      const numA = parseFloat(rawA.replace(/[^\d\.\-eE]/g, ''));
      const numB = parseFloat(rawB.replace(/[^\d\.\-eE]/g, ''));

      let cmp = 0;
      if (!isNaN(numA) && !isNaN(numB)) {
        cmp = numA - numB;
      } else {
        cmp = rawA.localeCompare(rawB, undefined, {numeric: true, sensitivity: 'base'});
      }

      if (cmp !== 0) return sortDirections[col] ? cmp : -cmp;
    }
    return 0;
  });

  // re-append in sorted order
  rows.forEach(r => tbody.appendChild(r));

  // atualiza classes visuais nos headers desta tabela
  if (table.tHead && table.tHead.rows[0]) {
    Array.from(table.tHead.rows[0].cells).forEach(th => th.classList.remove('sorted-asc','sorted-desc'));
    if (sortPriority.length) {
      const top = sortPriority[0];
      const header = table.tHead.rows[0].cells[top];
      if (header) header.classList.add(sortDirections[top] ? 'sorted-asc' : 'sorted-desc');
    }
  }
}

function sortTableToggle(table, colIndex) {
  // alterna direção para a coluna clicada
  sortDirections[colIndex] = !sortDirections[colIndex];
  // coloca coluna clicada no topo da prioridade
  sortPriority = [colIndex, ...sortPriority.filter(c => c !== colIndex)];
  applySort(table);
}

// Delegação de eventos: escuta cliques em qualquer <th> 
document.addEventListener('click', (e) => {
  const th = e.target.closest('th');
  if (!th) return;
  const table = th.closest('table');
  if (!table) return;
  if (!table.id || !table.id.startsWith('server')) return;

  // pega o índice real da célula
  const colIndex = th.cellIndex;
  sortTableToggle(table, colIndex);
});

function reattachSortEvents() {
  const table = getTableForServer();
  if (table) applySort(table);
}

(function addSortStyles(){
  const style = document.createElement('style');
  style.textContent = `
    th { cursor: pointer; }
    th.sorted-asc::after { content: " ▲"; font-size: 0.9em; color: inherit; }
    th.sorted-desc::after { content: " ▼"; font-size: 0.9em; color: inherit; }
  `;
  document.head.appendChild(style);
})();
</script>

</body>
</html>
