<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Report Issue - FL WebServer</title>
  
  <link rel ="stylesheet" href="/stylesheets/style.css">
  <link rel ="stylesheet" href="/stylesheets/trainingstyle.css">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<style>
    /* --- ESTRUTURA PRINCIPAL --- */
    /* Layout fluido com rolagem nativa que NUNCA corta o conteúdo */
    .main-content {
        width: 80%; /* Ocupa o espaço ao lado do menu */
        height: 100vh; /* Limita à altura da janela... */
        overflow-y: auto; /* ...e cria a barra de rolagem AQUI dentro */
        background-color: #F1F5F9; /* Fundo gelo padronizado */
        padding: 40px 2rem; /* Espaço generoso no topo e no fundo */
        box-sizing: border-box;
        display: block; /* Removemos o Flexbox daqui para evitar o corte */
    }

    /* O container do formulário (agora transparente, sem cara de "card gigante") */
    .server-card-large {
        width: 100%;
        max-width: 800px; /* Limita a largura para a leitura ficar agradável */
        margin: 0 auto; /* A MÁGICA: Centraliza horizontalmente de forma segura */
    }

    /* --- TIPOGRAFIA --- */
    .card-header-title {
        font-size: 2.2rem;
        font-weight: 700;
        color: #1E293B; 
        margin-bottom: 15px;
        padding-bottom: 20px;
        border-bottom: 2px solid #E2E8F0; 
        display: flex;
        align-items: center;
    }

    .card-header-desc {
        color: #64748B; 
        margin-bottom: 40px;
        font-size: 1.1rem;
        line-height: 1.6;
    }

    /* --- FORMULÁRIO --- */
    .form-group { margin-bottom: 25px; }
    
    .form-label { 
        font-weight: 600; 
        color: #1E293B; 
        font-size: 1rem; 
        margin-bottom: 10px; 
        display: block;
    }
    
    .form-input, .form-textarea { 
        width: 100%; 
        padding: 16px; 
        font-size: 1rem; 
        border: 1px solid #CBD5E1; 
        border-radius: 8px; 
        font-family: 'Inter', sans-serif; 
        box-sizing: border-box; 
        background-color: #FFFFFF; /* Inputs brancos para destacar do fundo gelo */
        color: #0F172A;
        transition: all 0.2s ease;
    }
    
    .form-textarea {
        resize: vertical; 
        min-height: 120px;
        line-height: 1.5;
    }

    .form-input:focus, .form-textarea:focus { 
        outline: none; 
        border-color: #63DBB8; 
        box-shadow: 0 0 0 4px rgba(99, 219, 184, 0.15);
    }

    .form-row-dual { 
        display: flex; 
        gap: 25px; 
    }

    /* Responsividade: Empilha os campos em telas menores */
    @media (max-width: 900px) {
        .form-row-dual {
            flex-direction: column;
            gap: 0;
        }
    }

    /* --- BOTÕES --- */
    .form-actions { 
        display: flex; 
        justify-content: flex-end; 
        align-items: center; 
        gap: 20px; 
        margin-top: 20px; 
        padding-top: 30px; 
        border-top: 1px solid #E2E8F0; 
    }
    
    .btn-primary { 
        background-color: #63DBB8; 
        color: #042F2E; 
        padding: 14px 30px; 
        border: none; 
        border-radius: 8px; 
        font-size: 1.1rem; 
        font-weight: 600; 
        cursor: pointer; 
        transition: transform 0.1s ease, background-color 0.2s; 
        display: flex; align-items: center; gap: 10px; 
    }
    .btn-primary:hover { 
        transform: translateY(-2px); 
        background-color: #4acda3; 
        box-shadow: 0 4px 12px rgba(99, 219, 184, 0.2);
    }
    
    .btn-secondary { 
        background-color: transparent; 
        color: #64748B; 
        padding: 12px 24px; 
        border: 1px solid transparent; 
        border-radius: 8px; 
        text-decoration: none; 
        font-weight: 600; 
        font-size: 1rem; 
        transition: all 0.2s;
    }
    .btn-secondary:hover { 
        color: #1E293B; 
        background-color: #E2E8F0; /* Ajuste sutil no hover */
    }
  </style>
</head>

<body class="page-training">

<div class="screen">
    
    <div class="side-menu" >
        <div class="menu-header">
            <a href="/" class="menu-logo">
                <i class="fa-solid fa-network-wired"></i>
                <h2>FL WebServer</h2>
            </a>
        </div>
        <nav class="menu-nav">
            <ul>
                <li><a href="/"><i class="fa-solid fa-table-list"></i><span>Dashboard</span></a></li>
                <li><a href="/be_a_server"><i class="fa-solid fa-handshake"></i><span>Be a server</span></a></li>
                <li><a href="/report" class="active"><i class="fa-solid fa-bullhorn"></i><span>Report</span></a></li>
            </ul>
        </nav>
        <div class="menu-footer">
            <a href="#"><i class="fa-regular fa-user"></i><span>User</span></a>
            <a href="#"><i class="fa-solid fa-right-from-bracket"></i><span>Logout</span></a>
        </div>
    </div>

    <div class="main-content" style="padding: 2rem; width: 100%; display: flex; justify-content: center;">
        
        <div class="server-card-large" style="max-width: 800px; width: 100%; height: fit-content;">
            
            <h1 class="card-header-title">
                <i class="fa-solid fa-bullhorn" style="color: #63DBB8; margin-right: 15px;"></i>
                Report an Issue
            </h1>
            
            <p class="card-header-desc">
                Help us maintain the integrity of the Federation. Report malicious nodes, bugs, or send us feature suggestions. Your feedback is anonymous.
            </p>

            <form action="/report" method="POST">
                
                <div class="form-row-dual">
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Subject</label>
                        <input type="text" class="form-input" name="subject" placeholder="e.g., Connection failure on Node #12" required>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Report Type</label>
                        <select class="form-input" name="type">
                            <option value="Technical Bug">Technical Bug</option>
                            <option value="Malicious Server">Malicious Server</option>
                            <option value="Performance Issue">Performance Issue</option>
                            <option value="Feature Request">Feature Request</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                </div>

                <div class="form-row-dual">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Target Server ID (Optional)</label>
                        <input type="text" class="form-input" name="targetId" placeholder="e.g., NODE-124B">
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Priority Level</label>
                        <select class="form-input" name="priority">
                            <option value="Low">Low</option>
                            <option value="Medium" selected>Medium</option>
                            <option value="High">High</option>
                            <option value="Critical">Critical</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Detailed Description</label>
                    <textarea class="form-textarea" name="description" placeholder="Please describe the issue in detail..." required></textarea>
                </div>

                <div class="form-actions">
                    <a href="/" class="btn-secondary">Cancel</a>
                    <button type="submit" class="btn-primary">
                        Send Report <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>
</body>
</html>