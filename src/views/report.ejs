<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Report Issue - FL WebServer</title>
  
  <link rel ="stylesheet" href="/stylesheets/style.css">
  <link rel ="stylesheet" href="/stylesheets/trainingstyle.css">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <style>


    .main-content {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        background-color: #f0f2f5;
        padding: 20px; 
        box-sizing: border-box;
        overflow: hidden;
    }


    /* --- TIPOGRAFIA --- */
    .card-header-title {
        font-size: 2.8rem;
        font-weight: 700;
        color: #1a2c4e;
        margin-bottom: 15px;
        padding-bottom: 20px;
        border-bottom: 3px solid #63DBB8;
        display: flex;
        align-items: center;
    }

    .card-header-desc {
        color: #64748b; 
        margin-bottom: 40px;
        font-size: 1.25rem;
        line-height: 1.6;
        max-width: 800px;
    }

    /* --- FORMULÁRIO --- */
    .form-group { margin-bottom: 30px; }
    
    .form-label { 
        font-weight: 700; 
        color: #1a2c4e; 
        font-size: 1.15rem; 
        margin-bottom: 15px; 
        display: block;
    }
    
    .form-input, .form-textarea { 
        width: 100%; 
        padding: 20px; 
        font-size: 1.1rem; 
        border: 2px solid #e2e8f0; 
        border-radius: 12px; 
        font-family: 'Inter', sans-serif; 
        box-sizing: border-box; 
        background-color: #fcfcfc;
        transition: all 0.2s ease;
    }
    
   
    .form-textarea {
        resize: vertical; 
        min-height: 150px;
        line-height: 1.5;
    }

    .form-input:focus, .form-textarea:focus { 
        outline: none; 
        border-color: #63DBB8; 
        background-color: #fff;
        box-shadow: 0 4px 12px rgba(99, 219, 184, 0.1);
    }

    .form-row-dual { display: flex; gap: 40px; }

    /* Botões */
    .form-actions { 
        display: flex; 
        justify-content: flex-end; 
        align-items: center; 
        gap: 25px; 
        margin-top: auto; 
        padding-top: 40px; 
        border-top: 2px solid #f1f5f9; 
    }
    
    .btn-primary { 
        background-color: #63DBB8; 
        color: #111214; 
        padding: 20px 45px; 
        border: none; 
        border-radius: 12px; 
        font-size: 1.25rem; 
        font-weight: 700; 
        cursor: pointer; 
        transition: transform 0.1s ease; 
        display: flex; align-items: center; gap: 12px; 
    }
    .btn-primary:hover { transform: scale(1.02); background-color: #4acda3; }
    
    .btn-secondary { 
        background-color: transparent; 
        color: #64748b; 
        padding: 15px 30px; 
        border: 2px solid transparent; 
        border-radius: 10px; 
        text-decoration: none; 
        font-weight: 600; 
        font-size: 1.1rem; 
    }
    .btn-secondary:hover { color: #334155; background-color: #e2e8f0; }

  </style>
</head>

<body class="page-training">

<div class="screen">
    
    <div class="side-menu" style="width: 280px;">
        <div class="menu-header">
            <a href="/" class="menu-logo">
                <i class="fa-solid fa-network-wired"></i>
                <h2>FL WebServer</h2>
            </a>
        </div>
        <nav class="menu-nav">
            <ul>
                <li><a href="/"><i class="fa-solid fa-table-list"></i><span>Dashboard</span></a></li>
                <li><a href="/be_a_server"><i class="fa-solid fa-handshake"></i><span>Be a server</span></a></li>
                <li><a href="/report" class="active"><i class="fa-solid fa-bullhorn"></i><span>Report</span></a></li>
            </ul>
        </nav>
        <div class="menu-footer">
            <a href="#"><i class="fa-regular fa-user"></i><span>User</span></a>
            <a href="#"><i class="fa-solid fa-right-from-bracket"></i><span>Logout</span></a>
        </div>
    </div>

    <div class="main-content" style="padding: 2rem; width: 100%; display: flex; justify-content: center;">
        
        <div class="server-card-large" style="max-width: 800px; width: 100%; height: fit-content;">
            
            <h1 class="card-header-title">
                <i class="fa-solid fa-bullhorn" style="color: #63DBB8; margin-right: 15px;"></i>
                Report an Issue
            </h1>
            
            <p class="card-header-desc">
                Help us maintain the integrity of the Federation. Report malicious nodes, bugs, or send us feature suggestions. Your feedback is anonymous.
            </p>

            <form action="/report" method="POST">
                
                <div class="form-row-dual">
                    <div class="form-group" style="flex: 2;">
                        <label class="form-label">Subject</label>
                        <input type="text" class="form-input" name="subject" placeholder="e.g., Connection failure on Node #12" required>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Report Type</label>
                        <select class="form-input" name="type">
                            <option value="Technical Bug">Technical Bug</option>
                            <option value="Malicious Server">Malicious Server</option>
                            <option value="Performance Issue">Performance Issue</option>
                            <option value="Feature Request">Feature Request</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                </div>

                <div class="form-row-dual">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Target Server ID (Optional)</label>
                        <input type="text" class="form-input" name="targetId" placeholder="e.g., NODE-124B">
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">Priority Level</label>
                        <select class="form-input" name="priority">
                            <option value="Low">Low</option>
                            <option value="Medium" selected>Medium</option>
                            <option value="High">High</option>
                            <option value="Critical">Critical</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Detailed Description</label>
                    <textarea class="form-textarea" name="description" placeholder="Please describe the issue in detail..." required></textarea>
                </div>

                <div class="form-actions">
                    <a href="/" class="btn-secondary">Cancel</a>
                    <button type="submit" class="btn-primary">
                        Send Report <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>
</body>
</html>